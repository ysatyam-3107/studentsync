<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#060912">

    <!-- ── Scrollable remote video grid — gets ALL space above control panel ── -->
    <ScrollView
        android:id="@+id/videoScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/controlPanel"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:fillViewport="true">

        <GridLayout
            android:id="@+id/remoteVideoContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="1"/>

    </ScrollView>

    <!-- ── Top gradient scrim ── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:layout_alignParentTop="true"
        android:background="@drawable/top_scrim_gradient"/>

    <!-- ── Bottom scrim behind control panel ── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="130dp"
        android:layout_alignParentBottom="true"
        android:background="@drawable/bottom_scrim_gradient"/>

    <!-- ── Local PiP — top-right ── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/localVideoContainer"
        android:layout_width="80dp"
        android:layout_height="110dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:layout_margin="14dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="20dp"
        app:cardBackgroundColor="#1A2238">
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </androidx.cardview.widget.CardView>

    <!-- ── Top info: count + timer ── -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_margin="14dp"
        android:orientation="vertical"
        android:gravity="start">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingEnd="12dp"
            android:background="@drawable/badge_dark_rounded">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="●"
                android:textColor="#4ADE80"
                android:textSize="7sp"
                android:layout_marginEnd="5dp"/>

            <TextView
                android:id="@+id/tvParticipantCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 in call"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tvCallDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="#94A3B8"
            android:textSize="11sp"
            android:layout_marginTop="6dp"
            android:paddingHorizontal="4dp"/>

    </LinearLayout>

    <!-- ══════════════════════════════════════════════
         COMPACT CONTROL PANEL — single row, 100dp tall
         Leaves maximum space for video grid
         ══════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/controlPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:paddingTop="14dp"
        android:paddingBottom="28dp"
        android:paddingHorizontal="8dp"
        android:background="@drawable/control_panel_bg">

        <!-- Single row: all 5 buttons + labels together -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Mute -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <ImageButton
                    android:id="@+id/btnMute"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/btn_control_normal"
                    android:src="@drawable/ic_mic"
                    android:padding="13dp"
                    android:contentDescription="Mute"
                    android:elevation="4dp"
                    android:scaleType="fitCenter"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mute"
                    android:textColor="#64748B"
                    android:textSize="10sp"
                    android:layout_marginTop="5dp"/>
            </LinearLayout>

            <!-- Camera -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <ImageButton
                    android:id="@+id/btnVideo"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/btn_control_normal"
                    android:src="@drawable/ic_video"
                    android:padding="13dp"
                    android:contentDescription="Camera"
                    android:elevation="4dp"
                    android:scaleType="fitCenter"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Camera"
                    android:textColor="#64748B"
                    android:textSize="10sp"
                    android:layout_marginTop="5dp"/>
            </LinearLayout>

            <!-- End Call — bigger, centered, stands out -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <ImageButton
                    android:id="@+id/btnEndCall"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/btn_end_call"
                    android:src="@drawable/ic_call_end"
                    android:padding="16dp"
                    android:contentDescription="End Call"
                    android:elevation="12dp"
                    android:scaleType="fitCenter"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="End"
                    android:textColor="#F87171"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginTop="5dp"/>
            </LinearLayout>

            <!-- Flip -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <ImageButton
                    android:id="@+id/btnSwitchCamera"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/btn_control_normal"
                    android:src="@android:drawable/ic_menu_rotate"
                    android:padding="13dp"
                    android:contentDescription="Flip Camera"
                    android:elevation="4dp"
                    android:scaleType="fitCenter"
                    app:tint="#90CAF9"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Flip"
                    android:textColor="#64748B"
                    android:textSize="10sp"
                    android:layout_marginTop="5dp"/>
            </LinearLayout>

            <!-- Mute All -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <ImageButton
                    android:id="@+id/btnMuteAll"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/btn_control_normal"
                    android:src="@android:drawable/ic_lock_silent_mode"
                    android:padding="13dp"
                    android:contentDescription="Mute All"
                    android:elevation="4dp"
                    android:scaleType="fitCenter"
                    app:tint="#90CAF9"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mute All"
                    android:textColor="#64748B"
                    android:textSize="10sp"
                    android:layout_marginTop="5dp"/>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</RelativeLayout>