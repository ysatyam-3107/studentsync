<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F0F">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottomNavCard"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ══════════════════════════════════════════
                 HEADER
                 ══════════════════════════════════════════ -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/dark_header_gradient"
                android:padding="24dp"
                android:paddingBottom="28dp">

                <!-- Profile photo + green online dot -->
                <FrameLayout
                    android:id="@+id/profileWrapper"
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentTop="true">

                    <ImageView
                        android:id="@+id/ivProfile"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_gravity="center"
                        android:background="@drawable/profile_icon_bg"
                        android:padding="2dp"
                        android:src="@drawable/ic_profile_circle"
                        android:clickable="true"
                        android:focusable="true"/>

                    <View
                        android:layout_width="13dp"
                        android:layout_height="13dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/online_dot"/>

                </FrameLayout>

                <!-- Left: app name, greeting, quote, pills, active rooms card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_toStartOf="@id/profileWrapper"
                    android:layout_marginEnd="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="StudySync"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="4dp"/>

                    <!-- Time-of-day greeting — set in Java -->
                    <TextView
                        android:id="@+id/tvWelcome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Good Morning 👋"
                        android:textSize="15sp"
                        android:textColor="#B0B0B0"
                        android:layout_marginBottom="10dp"/>

                    <!-- Motivational quote of the day -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✨"
                            android:textSize="12sp"
                            android:layout_marginEnd="6dp"/>

                        <TextView
                            android:id="@+id/tvQuote"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="The secret of getting ahead is getting started."
                            android:textSize="12sp"
                            android:textColor="#666666"
                            android:fontFamily="serif"
                            android:textStyle="italic"/>

                    </LinearLayout>

                    <!-- 🔥 Streak pill + 📚 Sessions pill -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="34dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="10dp"
                            android:paddingEnd="12dp"
                            android:background="@drawable/streak_pill_bg"
                            android:layout_marginEnd="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🔥"
                                android:textSize="13sp"
                                android:layout_marginEnd="5dp"/>

                            <TextView
                                android:id="@+id/tvStreak"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 day streak"
                                android:textColor="#FFA040"
                                android:textSize="12sp"
                                android:textStyle="bold"/>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="34dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="10dp"
                            android:paddingEnd="12dp"
                            android:background="@drawable/stat_pill_bg">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📚"
                                android:textSize="12sp"
                                android:layout_marginEnd="5dp"/>

                            <TextView
                                android:id="@+id/tvSessionCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 sessions"
                                android:textColor="#90CAF9"
                                android:textSize="12sp"
                                android:textStyle="bold"/>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Active Rooms card -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardActiveRooms"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="#1A1A1A">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="16dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:text="📚"
                                android:textSize="22sp"
                                android:layout_marginEnd="12dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvRoomCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0 Active Rooms"
                                    android:textSize="17sp"
                                    android:textStyle="bold"
                                    android:textColor="#FFFFFF"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Tap to manage your study sessions"
                                    android:textSize="12sp"
                                    android:textColor="#808080"
                                    android:layout_marginTop="3dp"/>

                            </LinearLayout>


                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                </LinearLayout>

            </RelativeLayout>

            <!-- ══════════════════════════════════════════
                 QUICK START — Create Room + Join Room
                 ══════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quick Start"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="14dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Create Room -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardCreateRoom"
                        android:layout_width="0dp"
                        android:layout_height="118dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="8dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/create_room_gradient"
                            android:padding="16dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:orientation="vertical">

                                <TextView
                                    android:text="➕"
                                    android:textSize="26sp"
                                    android:layout_marginBottom="6dp"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"/>

                                <TextView
                                    android:text="Create Room"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    android:textColor="#FFFFFF"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"/>

                                <TextView
                                    android:text="Start a new session"
                                    android:textSize="11sp"
                                    android:textColor="#CCE0FF"
                                    android:layout_marginTop="3dp"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"/>

                            </LinearLayout>

                        </RelativeLayout>

                    </androidx.cardview.widget.CardView>

                    <!-- Join Room -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardJoinRoom"
                        android:layout_width="0dp"
                        android:layout_height="118dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="8dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/join_room_gradient"
                            android:padding="16dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:orientation="vertical">

                                <TextView
                                    android:text="🔗"
                                    android:textSize="26sp"
                                    android:layout_marginBottom="6dp"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"/>

                                <TextView
                                    android:text="Join Room"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    android:textColor="#FFFFFF"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"/>

                                <TextView
                                    android:text="Enter a room code"
                                    android:textSize="11sp"
                                    android:textColor="#CCFFD6"
                                    android:layout_marginTop="3dp"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"/>

                            </LinearLayout>

                        </RelativeLayout>

                    </androidx.cardview.widget.CardView>

                </LinearLayout>

            </LinearLayout>

            <!-- ══════════════════════════════════════════
                 RECENT ROOMS — horizontally scrollable chips
                 ══════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Recent Rooms"
                        android:textSize="19sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>

                    <TextView
                        android:id="@+id/tvSeeAllRooms"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See all →"
                        android:textSize="12sp"
                        android:textColor="#4CAF50"
                        android:clickable="true"
                        android:focusable="true"/>

                </LinearLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:overScrollMode="never">

                    <LinearLayout
                        android:id="@+id/recentRoomsContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingBottom="4dp"/>

                </HorizontalScrollView>

                <TextView
                    android:id="@+id/tvNoRecentRooms"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No recent rooms yet — create or join one!"
                    android:textSize="13sp"
                    android:textColor="#555555"
                    android:visibility="gone"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

            <!-- ══════════════════════════════════════════
                 STATS ROW
                 ══════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your Stats"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="14dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Rooms stat -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="88dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="#131D2B">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="10dp">
                            <TextView
                                android:id="@+id/tvStatRooms"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:textColor="#4CAF50"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rooms"
                                android:textSize="11sp"
                                android:textColor="#506070"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Notes stat -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="88dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="#131D2B">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="10dp">
                            <TextView
                                android:id="@+id/tvStatNotes"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:textColor="#90CAF9"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Notes"
                                android:textSize="11sp"
                                android:textColor="#506070"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Messages stat -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="88dp"
                        android:layout_weight="1"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="#131D2B">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="10dp">
                            <TextView
                                android:id="@+id/tvStatMessages"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:textColor="#CE93D8"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Messages"
                                android:textSize="11sp"
                                android:textColor="#506070"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>

            </LinearLayout>

            <!-- ══════════════════════════════════════════
                 DAILY STUDY TIP
                 ══════════════════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardTip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="28dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#0D1F2D">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💡"
                        android:textSize="22sp"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="STUDY TIP"
                            android:textSize="10sp"
                            android:textColor="#4CAF50"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/tvTip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Use the Pomodoro technique — 25 min focus, 5 min break."
                            android:textSize="13sp"
                            android:textColor="#8A9BB0"/>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

    <include
        layout="@layout/layout_bottom_nav"
        android:id="@+id/bottomNavCard"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentBottom="true"/>

</RelativeLayout>