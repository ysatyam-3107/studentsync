<?xml version="1.0" encoding="utf-8"?>
<!--
    dialog_profile_photo.xml
    Used by MembersAdapter to show a member's full profile photo.
    Place in: res/layout/dialog_profile_photo.xml
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#1A1A1A">

    <!-- Large circular profile photo -->
    <ImageView
        android:id="@+id/ivFullProfilePhoto"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_profile_circle"
        android:layout_marginBottom="16dp" />

    <!-- Member's display name -->
    <TextView
        android:id="@+id/tvFullProfileName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center" />

</LinearLayout>