<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F0F">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ══════════════════════════════════════
                 HEADER — matches dashboard style
                 ══════════════════════════════════════ -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/dark_header_gradient"
                android:padding="24dp"
                android:paddingBottom="32dp">

                <!-- Title block -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Study Rooms"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="4dp"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="●"
                            android:textColor="#4ADE80"
                            android:textSize="8sp"
                            android:layout_marginEnd="6dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Connect with your study partners"
                            android:textSize="14sp"
                            android:textColor="#808080"/>

                    </LinearLayout>

                </LinearLayout>

            </RelativeLayout>

            <!-- ══════════════════════════════════════
                 MODE SELECTOR TABS — Create / Join
                 ══════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="4dp">

                <LinearLayout
                    android:id="@+id/tabCreate"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/tab_active_bg"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="➕  Create Room"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/tabJoin"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/tab_inactive_bg"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔗  Join Room"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#607080"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ══════════════════════════════════════
                 CREATE ROOM PANEL
                 ══════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/panelCreate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="20dp"
                android:visibility="visible">

                <!-- Illustration card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardCreateRoom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="10dp"
                    android:layout_marginBottom="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/create_room_gradient"
                        android:padding="24dp"
                        android:minHeight="130dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🧠"
                                android:textSize="32sp"
                                android:layout_marginBottom="10dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Create New Room"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Start a fresh study session instantly"
                                android:textSize="13sp"
                                android:textColor="#CCE0FF"
                                android:layout_marginTop="5dp"/>

                        </LinearLayout>

                    </RelativeLayout>

                </androidx.cardview.widget.CardView>

                <!-- What you get info cards -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="#131D2B">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="💬" android:textSize="22sp" android:layout_marginBottom="6dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Group Chat" android:textColor="#FFFFFF"
                                android:textSize="13sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Real-time messaging" android:textColor="#506070"
                                android:textSize="11sp" android:layout_marginTop="3dp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="#131D2B">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="📁" android:textSize="22sp" android:layout_marginBottom="6dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Notes" android:textColor="#FFFFFF"
                                android:textSize="13sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Share files &amp; docs" android:textColor="#506070"
                                android:textSize="11sp" android:layout_marginTop="3dp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="#131D2B">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🎥" android:textSize="22sp" android:layout_marginBottom="6dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Video Call" android:textColor="#FFFFFF"
                                android:textSize="13sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Face-to-face study" android:textColor="#506070"
                                android:textSize="11sp" android:layout_marginTop="3dp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>

                <!-- Create button -->
                <Button
                    android:id="@+id/btnCreateRoom"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:text="Create My Study Room"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/create_btn_bg"
                    android:elevation="6dp"
                    android:layout_marginBottom="28dp"/>

            </LinearLayout>

            <!-- ══════════════════════════════════════
                 JOIN ROOM PANEL
                 ══════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/panelJoin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="20dp"
                android:visibility="gone">

                <!-- Illustration card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="10dp"
                    android:layout_marginBottom="20dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/join_room_gradient"
                        android:padding="24dp"
                        android:minHeight="120dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🔗"
                                android:textSize="32sp"
                                android:layout_marginBottom="10dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Join a Room"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Enter the 6-digit code from your host"
                                android:textSize="13sp"
                                android:textColor="#CCFFD6"
                                android:layout_marginTop="5dp"/>

                        </LinearLayout>

                    </RelativeLayout>

                </androidx.cardview.widget.CardView>

                <!-- Code input card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="6dp"
                    app:cardBackgroundColor="#161F2C"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="22dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ROOM CODE"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="#4CAF50"
                            android:letterSpacing="0.12"
                            android:layout_marginBottom="12dp"/>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="e.g. AB12CD"
                            app:boxBackgroundMode="filled"
                            app:boxBackgroundColor="#0D1520"
                            app:boxStrokeColor="#4CAF50"
                            app:hintTextColor="#506070"
                            app:boxStrokeWidth="2dp"
                            app:boxCornerRadiusTopStart="14dp"
                            app:boxCornerRadiusTopEnd="14dp"
                            app:boxCornerRadiusBottomStart="14dp"
                            app:boxCornerRadiusBottomEnd="14dp"
                            android:layout_marginBottom="8dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etRoomCode"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textCapCharacters"
                                android:textColor="#FFFFFF"
                                android:textSize="22sp"
                                android:letterSpacing="0.18"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:padding="16dp"
                                android:maxLength="6"/>

                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Code is case-insensitive and 6 characters"
                            android:textSize="11sp"
                            android:textColor="#3D5060"/>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Join button -->
                <Button
                    android:id="@+id/btnJoinRoom"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:text="Join Study Room"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/join_button_bg"
                    android:elevation="6dp"
                    android:layout_marginBottom="28dp"/>

            </LinearLayout>

            <!-- Progress bar — centered, shown during loading -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="20dp"
                android:indeterminateTint="#4CAF50"
                android:visibility="gone"/>

        </LinearLayout>

    </ScrollView>

</RelativeLayout>